# Copy this file to .env and fill in only the providers you want to use.
# Never commit real API keys.

FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TUSHARE_TOKEN=

# yfinance uses Yahoo Finance public endpoints and does not need an API key.
YFINANCE_ENABLED=true

# Optional LLM settings for future research-summary expansion.
# The MVP does not call an LLM automatically.
LLM_PROVIDER=moonshot
LLM_BASE_URL=https://api.moonshot.cn/anthropic
LLM_MODEL=kimi-k2.6
LLM_API_KEY=

# SEC asks automated clients to identify themselves with contact information.
# Example: market-intelligence-agent/0.1 your_email@example.com
SEC_USER_AGENT=market-intelligence-agent/0.1 contact@example.com

# Cache time-to-live in seconds. Default: 21600 seconds = 6 hours.
CACHE_TTL_SECONDS=21600
